# ============================================
# GPTNiX Backend - Environment Configuration
# ============================================

# Server
PORT=8080
NODE_ENV=production

# Firebase (REQUIRED)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# LLM Providers (At least one required)
DEEPSEEK_API_KEY=sk-xxx
OPENAI_API_KEY=sk-xxx
OPENROUTER_API_KEY=sk-xxx

# Web Search (Optional - fallback to DuckDuckGo if none)
TAVILY_API_KEY=tvly-xxx
SERPER_API_KEY=xxx
SCRAPE_DEV_API_KEY=xxx

# Image Generation (Optional)
REPLICATE_API_TOKEN=r8_xxx
REPLICATE_MODEL=minimax/image-01

# External Tools (Optional)
WEATHER_API_KEY=xxx
TMDB_API_KEY=xxx
GEOAPIFY_API_KEY=xxx
WOLFRAM_APP_ID=xxx

# Vector DB for RAG (Optional)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=xxx

# Qdrant keep-alive / wake-up (managed instances may sleep after inactivity)
QDRANT_KEEPALIVE_ENABLED=true
# Recommended: 8-15 minutes (in milliseconds)
QDRANT_KEEPALIVE_INTERVAL_MS=720000
QDRANT_WAKEUP_MAX_RETRIES=8
QDRANT_WAKEUP_RETRY_BASE_MS=1500
QDRANT_AUTO_ENSURE_COLLECTIONS=true

# Voice (Optional)
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_MODEL=tts-1

# App Config
DEFAULT_MODEL=deepseek-chat
MAX_TOKENS=4096
MAX_HISTORY=20
ENABLE_WEB_SEARCH=true
ENABLE_VOICE=true
ENABLE_RAG=true
ENABLE_BILLING=true


# ─────────────────────────────────────────
# Response Polisher (style-only)
# ─────────────────────────────────────────
POLISH_ENABLED=false               # true = enable LLM polish (L2); L1 rules always run
POLISH_PROVIDER=auto               # auto | openai | deepseek (auto picks first available key)
POLISH_MODEL=                      # empty = provider default (gpt-4o-mini / deepseek-chat)
POLISH_MIN_CHARS=120               # skip L2 for answers shorter than this (non-whitespace chars)
POLISH_MAX_LATENCY_MS=1800         # max ms for non-stream L2 polish before timeout → L1 fallback
POLISH_STREAM_MAX_LATENCY_MS=900   # max ms for stream L2 polish (tighter budget, user waiting)
POLISH_MAX_INPUT_CHARS=6000        # chunk answers longer than this for polish
POLISH_MAX_TOKENS=1500             # max tokens for polish LLM response
POLISH_LEVEL1_ONLY=false           # true = L1 rules only (no LLM call, even if POLISH_ENABLED)
POLISH_DEBUG=false                 # true = log hash+length of before/after (no plaintext)